# Email Configuration for Contact Form
# To set up email sending, follow these steps:

# 1. Using Gmail:
#    - Go to https://myaccount.google.com/apppasswords
#    - Select "Mail" and "Windows Computer" (or your device)
#    - Google will generate a 16-character app password
#    - Copy it and paste it below (without spaces)

# 2. Create a .env.local file (do NOT commit this file - it's in .gitignore)
# 3. Copy this file and rename it to .env.local
# 4. Fill in your credentials below
# 5. Restart the dev server (npm run dev)

# Your Gmail address
EMAIL_USER=your-email@gmail.com

# Your App Password from Gmail (not your regular password)
EMAIL_PASSWORD=your-app-password-16-chars-no-spaces

# Alternative: Using other email services
# For Outlook/Hotmail:
# EMAIL_USER=your-email@outlook.com
# EMAIL_PASSWORD=your-password

# For custom SMTP:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password

# ============================================
# Supabase Configuration
# ============================================
# To set up Supabase authentication:
# 1. Go to https://supabase.com and create a new project
# 2. Go to Settings > API in your Supabase dashboard
# 3. Copy the Project URL and Anon Key below
# 4. These are public keys (safe to expose in frontend code)

# Your Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase Anon Key (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
